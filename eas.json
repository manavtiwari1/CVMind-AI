{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
