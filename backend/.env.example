# Port for the Express backend server
PORT=5000

# Google Gemini API Key (obtain for free from https://aistudio.google.com/)
# Configure this key to enable global free resume checks for all users.
# If omitted, the application will require users to input their own keys in the frontend interface.
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB URI (configure to enable permanent cloud database for production/Vercel/Render)
# If omitted, the application will automatically fall back to local JSON document db.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/resumetrics?retryWrites=true&w=majority

